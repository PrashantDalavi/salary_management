#!/bin/bash -e

# Remove stale server pid
rm -f tmp/pids/server.pid

# Wait for database to be ready
echo "Waiting for database..."
while ! pg_isready -h host.docker.internal -U pdalavi -d employee_management_development -q 2>/dev/null; do
  sleep 1
done
echo "Database is ready!"

# Run any pending migrations
echo "Running migrations..."
./bin/rails db:migrate

# Build JS assets and watch for changes in background
echo "Starting esbuild watcher..."
yarn build --watch=forever &

# Start Rails server
echo "Starting Rails server..."
exec ./bin/rails server -b 0.0.0.0
